define min fn(self, b) {
    if [self < b] {return self}
    if [b < self] {return b}
}

define mint fn(self, a) {
    if [self > a] {return a}
    if [self < a] {return self}
}

define multiplier fn(self, x) {
    return [self * x]
}

set x 10
set y 20

set minim x.min(y)
set aminim x.mint(y).multiplier(3)


writeln "Minimum is " .. minim
writeln "Another minimum is " .. aminim
 