
define max fn(self, b) {
    if [self  > b] {return self}
    if [self < b] {return b}
}

define min fn(self, b) {
    writeln "min called"
    writeln self
    writeln b
    if [self < b] {return self}
    if [self > b] {return self}
}

define maxer proc(x, y) {
    if [x > y] {return x}
    if [y > x] {return y}
}

define factorial proc(x) {
    if [x == 0] {return 1}
    if [x != 0] {return [x * [factorial x-1]]}
}

set a 10
set b 20
set word "    word    "
set word word.trim().toUpper().len()

set maximum a.max(b)
set minimum a.min(b)

set newmax [maxer a b]
evolve "writeln 42"

writeln "Maximum is " .. maximum
writeln "Minimum is " .. minimum
writeln "Another maximum is " .. newmax
writeln word
