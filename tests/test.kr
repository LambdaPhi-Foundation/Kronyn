
define factorial fn(self) {
       if [$self == 0] {return 1} {return [$self * [$self - 1].factorial()]}
}

define mult fn(self, x) {
       if [$x == 0] {return 0} {return [$self + $self.mult([$x - 1])]}
}

define printer proc(msg, n) {
       if [$n == 0] {return ""} {
       	  writeln $msg
	  printer $msg [$n - 1]
	}
}

printer "Kronyn" 5
writeln 4.factorial()
writeln "Hello world"
writeln 3.mult(2)
